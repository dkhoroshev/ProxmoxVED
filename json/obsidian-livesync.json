                "cpu": 1,
                "ram": 1024,
                "hdd": 8,
                "os": "Debian",
                "version": "13"
            }
        }
    ],
    "default_credentials": {
        "username": "admin",
        "password": null
    },
    "notes": [
        {
            "text": "Install the Self-hosted LiveSync plugin in Obsidian. The GitHub release ZIP is a client plugin, not server software.",
            "type": "info"
        },
        {
            "text": "Connection details are stored in /opt/obsidian-livesync/.env. Use HTTPS through a reverse proxy for mobile Obsidian clients.",
            "type": "warning"
        },
        {
            "text": "Enable end-to-end encryption and path obfuscation in the plugin before synchronising sensitive notes.",
            "type": "info"
        }
    ]
