    "description": "A CouchDB server configured for synchronising Obsidian vaults with the Self-hosted LiveSync plugin.",
    "install_methods": [
        {
            "type": "default",
            "script": "ct/obsidian-livesync.sh",
            "config_path": "/opt/obsidian-livesync/.env",
